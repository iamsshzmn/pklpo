# EditorConfig для проекта PKLPO
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyw,pyi}]
indent_style = space
indent_size = 4
max_line_length = 88
insert_final_newline = true

[*.{yaml,yml}]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.{json,toml}]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.{md,rst}]
indent_style = space
trim_trailing_whitespace = false
max_line_length = 100
insert_final_newline = true

[*.sql]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.{env,ini}]
indent_style = space
indent_size = 2
insert_final_newline = true

[Makefile]
indent_style = tab
insert_final_newline = true

[docker-compose*.yml]
indent_style = space
indent_size = 2
insert_final_newline = true

[Dockerfile*]
indent_style = space
indent_size = 2
insert_final_newline = true
