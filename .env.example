# =============================================================================
# pklpo - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# This is the canonical reference for all env vars used by the project.
#
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Environment mode: development | staging | production
ENVIRONMENT=development
# Enable debug mode (verbose logging, extra checks)
DEBUG=false

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# [REQUIRED] Core database credentials (used by docker-compose and the app)
POSTGRES_USER=pklpo_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=pklpo

# Connection settings (prefix: DB_)
DB_HOST=localhost
DB_PORT=5432

# Full connection URL (takes precedence over individual DB_* vars if set)
# DATABASE_URL=postgresql+asyncpg://pklpo_user:CHANGE_ME@localhost:5432/pklpo

# SSL mode: true | false | require | disable (auto-detected if omitted)
# DATABASE_SSL=disable

# Connection pool tuning
# DB_POOL_SIZE=10
# DB_POOL_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# OKX Exchange API
# -----------------------------------------------------------------------------
# [OPTIONAL] Leave empty to disable trading; required for live data sync
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_BASE_URL=https://www.okx.com
# Reference only: current OKX 1W anchor is code-defined in src/config/settings.py
# as 1777824000000 (2026-05-03T16:00:00Z / Monday 00:00 UTC+8).

# Rate limiting
# OKX_MAX_REQUESTS_PER_SECOND=10
# OKX_MAX_REQUESTS_PER_MINUTE=600

# Retry behaviour
# OKX_MAX_RETRIES=3
# OKX_BASE_DELAY=1.0
# OKX_MAX_DELAY=60.0
# OKX_TIMEOUT=30

# OKX sandbox mode (env_validator.py legacy)
# OKX_SANDBOX=false

# -----------------------------------------------------------------------------
# Candles / Sync
# -----------------------------------------------------------------------------
# Adapter override: auto-detected if omitted
# CANDLES_ADAPTER=

# Instruments cache directory (used in Airflow DAGs and sync tasks)
# INSTRUMENTS_CACHE_DIR=/tmp/pklpo

# -----------------------------------------------------------------------------
# Features Pipeline
# -----------------------------------------------------------------------------
# Chunking
# FEATURES_CHUNK_SIZE=200000
# FEATURES_MAX_LOOKBACK=200
# FEATURES_OVERLAP_SIZE=200

# Database batch operations
# FEATURES_BATCH_SIZE=50000
# FEATURES_INSERT_CHUNK_SIZE=50000

# Quality thresholds
# FEATURES_MIN_FILL_RATE=0.5
# FEATURES_MAX_NAN_RATIO=       # gate_validator override
# FEATURES_VALIDATE_RESULTS=true

# TA backend: auto | pandas_ta | talib | fallback
# FEATURES_TA_BACKEND=auto

# Normalization
# FEATURES_VOLATILITY_NORMALIZE=true
# FEATURES_NORMALIZE_WINDOW=20

# Performance
# FEATURES_PARALLEL_WORKERS=4
# FEATURES_BATCH_TIMEOUT=300

# Upsert tuning
# FEATURES_UPSERT_MAX_BATCH_SIZE=200
# FEATURES_UPSERT_TARGET_SQL_PARAMS=15000

# Warm-up trim (set true to skip warm-up row removal)
# FEATURES_SKIP_WARMUP_TRIM=false

# Debug & verbosity
# FEATURES_VERBOSE=false
# FEATURES_DEBUG=false

# Diagnostic mode (single-row inserts for debugging)
# DIAGNOSTIC_SINGLE_ROW=0

# -----------------------------------------------------------------------------
# Quant Stack (Phase 3)
# -----------------------------------------------------------------------------
# Bar type: time | dollar
# QUANT_BARS_MODE=time
# QUANT_DOLLAR_BAR_VALUE=200000
# QUANT_DOLLAR_BAR_MIN_TRADES=1

# Triple Barrier labeling
# QUANT_TRIPLE_PT=0.02
# QUANT_TRIPLE_SL=0.01
# QUANT_TRIPLE_MAX_H=48

# Cross-validation
# QUANT_PURGED_KFOLD_SPLITS=5
# QUANT_EMBARGO_PCT=0.01
# QUANT_CPCV_N_GROUPS=6
# QUANT_CPCV_N_TEST_GROUPS=2
# QUANT_CPCV_MAX_PATHS=50

# Feature selection
# QUANT_FEATURE_SELECTION_METHOD=mda
# QUANT_FEATURE_SELECTION_N_FEATURES=50

# Metalabeling
# QUANT_METALABEL_MODEL=rf
# QUANT_METALABEL_CALIBRATE=true
# QUANT_METALABEL_N_ESTIMATORS=500

# Metrics
# QUANT_SHARPE_PERIODS=365
# QUANT_DSR_SIGNIFICANCE=0.05

# -----------------------------------------------------------------------------
# Risk Management
# -----------------------------------------------------------------------------
# Position limits
# RISK_DEFAULT_RISK_PER_TRADE=0.02
# RISK_MAX_RISK_PER_TRADE=0.05
# RISK_MAX_POSITION_SIZE_USD=10000
# RISK_MAX_TOTAL_EXPOSURE_USD=50000
# RISK_MAX_LEVERAGE=20
# RISK_MAX_CONCURRENT_POSITIONS=10

# Loss limits
# RISK_DAILY_LOSS_LIMIT=0.10
# RISK_WEEKLY_LOSS_LIMIT=0.20

# Cooldowns (seconds)
# RISK_COOLDOWN_AFTER_LOSS_SEC=3600
# RISK_COOLDOWN_BETWEEN_TRADES_SEC=300

# Circuit breaker
# RISK_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# RISK_CIRCUIT_BREAKER_TIMEOUT_SEC=1800

# Kill switch
# RISK_ENABLE_KILLSWITCH=true
# RISK_KILLSWITCH_AUTO_ACTIVATE_ON_LOSS=0.15

# Bootstrap guards from env (semicolon-separated: type:name;type:name)
# RISK_GUARDS=

# -----------------------------------------------------------------------------
# Retry (unified)
# -----------------------------------------------------------------------------
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0
# RETRY_MAX_DELAY=60.0
# RETRY_EXPONENTIAL_BASE=2.0
# RETRY_JITTER=true

# Database-specific retry overrides
# RETRY_DB_MAX_ATTEMPTS=3
# RETRY_DB_BASE_DELAY=1.0
# RETRY_DB_MAX_DELAY=10.0

# API-specific retry overrides
# RETRY_API_MAX_ATTEMPTS=5
# RETRY_API_BASE_DELAY=1.0
# RETRY_API_MAX_DELAY=30.0

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
# CACHE_METADATA_TTL_HOURS=1
# CACHE_INSTRUMENT_TTL_HOURS=1
# CACHE_VALIDATION_TTL_MINUTES=5
# CACHE_AUTO_REFRESH_ENABLED=true
# CACHE_AUTO_REFRESH_INTERVAL_HOURS=1
# CACHE_MAX_SIZE_MB=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Global log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Log format: json | text
LOG_FORMAT=text
# Log to file (path); omit for stdout only
# LOG_FILE=
# LOG_FILE_MAX_MB=10
# LOG_BACKUP_COUNT=5
# LOG_VERBOSITY=normal
# LOG_CATEGORIES=
# Log directory override
# LOG_DIR=

# Market-meta subsystem logging
# MARKET_META_LOG_LEVEL=WARNING
# MARKET_META_LOG_FILE=/tmp/pklpo/market_meta.log
# MARKET_META_FILE_LOG=false
# MARKET_META_DATA_DIR=/tmp/pklpo/data

# Features-specific log format (legacy, prefer LOG_FORMAT)
# FEATURES_LOG_FORMAT=text
# FEATURES_LOG_FILE=/tmp/pklpo/features.log
# FEATURES_LOG_VERBOSITY=normal
# FEATURES_LOG_CATEGORIES=

# Progress bars (set 1 to hide tqdm bars)
# TQDM_DISABLE=0

# -----------------------------------------------------------------------------
# Observability (Prometheus / Pushgateway)
# -----------------------------------------------------------------------------
OBSERVABILITY_PROMETHEUS_ENABLED=false
OBSERVABILITY_PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
OBSERVABILITY_METRICS_PREFIX=pklpo
OBSERVABILITY_JOB_NAME=features_pipeline

# -----------------------------------------------------------------------------
# Alerts - Email
# -----------------------------------------------------------------------------
# SMTP configuration for quality alert emails
# ALERT_EMAIL_SMTP_SERVER=smtp.example.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_USERNAME=
# ALERT_EMAIL_PASSWORD=
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_TO=team@example.com

# Airflow alert email recipients (comma-separated)
# AIRFLOW_ALERT_EMAIL=data-team@company.com

# -----------------------------------------------------------------------------
# Alerts - Slack
# -----------------------------------------------------------------------------
# Incoming webhook URL for Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Send notifications on success too (default: only failures)
# SLACK_SUCCESS_NOTIFICATIONS=false

# -----------------------------------------------------------------------------
# Alerts - Telegram
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
# Airflow's own Postgres (separate from app DB)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME
AIRFLOW_DB_HOST=postgres
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow_db

# Airflow web UI admin password
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME

# Airflow encryption keys
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW_SECRET_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# PgAdmin
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Metabase
# -----------------------------------------------------------------------------
MB_ENCRYPTION_SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Grafana (monitoring stack)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# App-level (env_validator.py legacy)
# -----------------------------------------------------------------------------
# MAX_WORKERS=4
# BATCH_SIZE=100

# -----------------------------------------------------------------------------
# MCP Servers (Claude Code tooling)
# -----------------------------------------------------------------------------
# Postgres URL for the pklpo MCP server
PKLPO_MCP_POSTGRES_URL=postgresql://pklpo_user:CHANGE_ME@localhost:5432/pklpo
# GitHub Personal Access Token for the GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=CHANGE_ME
# Notion integration token for the Notion MCP server
NOTION_TOKEN=CHANGE_ME
