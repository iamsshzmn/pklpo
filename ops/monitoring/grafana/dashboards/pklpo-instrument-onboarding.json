{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "pklpo_pipeline_bootstrap_state_rows",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Bootstrap Progress",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "list" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum by (state) (pklpo_feature_eligibility_symbols{timeframe=~\"$timeframe\"})",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "Eligibility Funnel",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (to_state) (increase(pklpo_feature_eligibility_transitions_total[1h]))",
          "legendFormat": "{{to_state}}",
          "refId": "A"
        }
      ],
      "title": "Eligibility Transitions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 5 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "increase(pklpo_feature_eligibility_transitions_total{from_state=\"insufficient_history\",to_state=\"eligible\"}[1h])",
          "legendFormat": "insufficient_history to eligible",
          "refId": "A"
        }
      ],
      "title": "Warm-up Transitions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "pklpo_feature_eligible_total{timeframe=~\"$timeframe\"}",
          "legendFormat": "{{timeframe}}",
          "refId": "A"
        }
      ],
      "title": "Eligible Symbols",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "pklpo_market_selection_universe_size",
          "legendFormat": "universe",
          "refId": "A"
        },
        {
          "expr": "pklpo_market_selection_eligible_count{timeframe=~\"$timeframe\"}",
          "legendFormat": "eligible {{timeframe}}",
          "refId": "B"
        }
      ],
      "title": "Universe Size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1800 },
              { "color": "red", "value": 3600 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 10 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "pklpo_feature_eligibility_stale_seconds",
          "legendFormat": "stale seconds",
          "refId": "A"
        },
        {
          "expr": "pklpo_feature_eligibility_invalid_total",
          "legendFormat": "invalid history",
          "refId": "B"
        },
        {
          "expr": "sum by (timeframe) (pklpo_feature_eligibility_lost{timeframe=~\"$timeframe\"})",
          "legendFormat": "lost {{timeframe}}",
          "refId": "C"
        }
      ],
      "title": "Eligibility Staleness",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pklpo", "instrument", "onboarding"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(pklpo_feature_eligible_total, timeframe)",
        "hide": 0,
        "includeAll": true,
        "label": "timeframe",
        "multi": true,
        "name": "timeframe",
        "options": [],
        "query": "label_values(pklpo_feature_eligible_total, timeframe)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "PKLPO Instrument Onboarding",
