{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Freshness Lag (seconds)",
      "description": "Data freshness lag per timeframe. SLA thresholds: 1m=90s, 5m=180s, 15m=360s, 1H=600s, 4H=1800s, 1D=7200s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "pklpo_data_freshness_lag_seconds",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Fill Rate",
      "description": "OHLCV data fill rate per timeframe. Threshold: 99.5%",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "rate",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percentunit",
          "min": 0.9,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "pklpo_data_fill_rate",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Hole Rate (missing bars)",
      "description": "Missing bars rate per timeframe. Threshold: 0.1%",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "rate",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percentunit",
          "min": 0,
          "max": 0.01,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.0005 },
              { "color": "red", "value": 0.001 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "pklpo_data_hole_rate",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Duplicate Rate",
      "description": "Duplicate rows detected. Should always be 0.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "count",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(pklpo_duplicate_rows_detected_total[5m])",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "UPSERT Duration (p50 / p95 / p99)",
      "description": "UPSERT batch execution time percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pklpo_upsert_duration_seconds_bucket[15m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pklpo_upsert_duration_seconds_bucket[15m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pklpo_upsert_duration_seconds_bucket[15m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Batch Size Distribution",
      "description": "UPSERT batch size histogram",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "bucketSize": 25,
        "combine": false,
        "fillOpacity": 80
      },
      "targets": [
        {
          "expr": "pklpo_batch_size_current",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Data Quality Score",
      "description": "Composite data quality score (0.0-1.0). Higher is better.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "pklpo_data_quality_score",
          "legendFormat": "{{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Features Calculation Duration",
      "description": "Time spent calculating features per symbol/timeframe",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "seconds",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pklpo_features_calculation_duration_seconds_bucket[15m]))",
          "legendFormat": "p95 {{symbol}} {{timeframe}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "UPSERT Failures & Rows Written",
      "description": "Failure rate and throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "count/min",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failures" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(pklpo_features_rows_written_total[5m]) * 60",
          "legendFormat": "rows/min {{symbol}} {{timeframe}}",
          "refId": "A"
        },
        {
          "expr": "rate(pklpo_upsert_failures_total[5m]) * 60",
          "legendFormat": "failures",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["pklpo", "data-quality", "phase-1"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "PKLPO Data Quality",
  "uid": "pklpo-data-quality",
  "version": 1
}
